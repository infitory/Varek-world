# Anthropic API key for AI-assisted generation.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the default model. Defaults to claude-opus-4-7.
# VAREK_MODEL=claude-opus-4-7

# Optional: override ports.
# VAREK_API_PORT=5174
# VAREK_WEB_PORT=5173

# Optional: path to the compendium. Defaults to ./varek
# VAREK_ROOT=./varek
